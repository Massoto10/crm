{
  "name": "stn-crm",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @stn-crm/web",
    "dev:api": "npm run start:dev --workspace @stn-crm/api",
    "dev:web": "npm run dev --workspace @stn-crm/web",
    "build": "npm run build --workspace @stn-crm/api && npm run build --workspace @stn-crm/web",
    "db:generate": "npm run prisma:generate --workspace @stn-crm/database",
    "db:migrate": "npm run prisma:migrate --workspace @stn-crm/database",
    "db:seed": "npm run prisma:seed --workspace @stn-crm/database"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
