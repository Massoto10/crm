# ── API STN CRM — variáveis de produção (Railway/Render) ──
# Copie para as env vars do serviço. NÃO commitar valores reais.

# Banco: Supabase (projeto stn-crm). Pegue a SENHA em:
# Supabase → Project Settings → Database → Connection string → "Session pooler" (porta 5432).
DATABASE_URL="postgresql://postgres.smnysnqwpkmrjptkpuhn:[SUA_SENHA]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Segredo do JWT — gere um forte:  openssl rand -hex 48
PROCESS_SECRET="<gere_com_openssl_rand_hex_48>"

# Origem do frontend (domínio da Vercel) — para CORS
WEB_ORIGIN="https://SEU-APP.vercel.app"

# Porta (Railway injeta PORT automaticamente; local usa 3333)
PORT=3333

# ── Evolution API (WhatsApp) — roda num VPS Docker separado ──
EVOLUTION_API_URL="https://SEU-EVOLUTION.seudominio.com"
# gere:  openssl rand -hex 24
EVOLUTION_API_KEY="<gere_com_openssl_rand_hex_24>"
# token do webhook (mesmo valor no WEBHOOK_GLOBAL_URL do Evolution) — gere:  openssl rand -hex 24
WA_WEBHOOK_TOKEN="<gere_com_openssl_rand_hex_24>"
