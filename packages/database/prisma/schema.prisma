generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  active
  trial
  paused
  churn
}

enum ClientClassification {
  strategic
  growth
  standard
  at_risk
}

enum ChannelType {
  whatsapp
  instagram
  email
  site
  manual
}

enum CustomerLifecycleStage {
  new
  qualified
  proposal
  won
  lost
  support
}

enum LeadTemperature {
  hot
  warm
  cold
}

enum Priority {
  high
  medium
  low
}

enum LabelCategory {
  profile
  behavior
  deal
  risk
  channel
}

enum ConversationStatus {
  pending
  open
  waiting_customer
  waiting_agent
  closed
}

enum SlaStatus {
  on_time
  warning
  late
}

enum SenderType {
  agent
  end_customer
  system
}

enum TaskStatus {
  open
  done
  canceled
}

enum UserRole {
  admin
  agent
}

enum ScheduledMessageStatus {
  pending
  sent
  failed
  canceled
}

model CrmClient {
  id                String               @id @default(cuid())
  legalName         String               @map("legal_name")
  tradeName         String               @map("trade_name")
  documentNumber    String?              @map("document_number")
  segment           String
  planName          String               @map("plan_name")
  status            ClientStatus
  classification    ClientClassification
  ownerName         String               @map("owner_name")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  channels          ClientChannel[]
  customers         EndCustomer[]
  conversations     Conversation[]
  labels            Label[]
  tasks             Task[]
  departments       Department[]
  agents            Agent[]
  quickMessages     QuickMessage[]
  leadStatuses      LeadStatus[]
  leadSources       LeadSource[]
  settings          Setting[]
  scheduledMessages ScheduledMessage[]

  @@index([status])
  @@map("crm_clients")
}

model ClientChannel {
  id                String      @id @default(cuid())
  crmClientId       String      @map("crm_client_id")
  channelType       ChannelType @map("channel_type")
  displayName       String      @map("display_name")
  externalReference String?     @map("external_reference")
  isActive          Boolean     @default(true) @map("is_active")
  crmClient         CrmClient   @relation(fields: [crmClientId], references: [id], onDelete: Cascade)

  @@index([crmClientId])
  @@map("client_channels")
}

model Department {
  id            String         @id @default(cuid())
  crmClientId   String         @map("crm_client_id")
  name          String
  permissions   Json           @default("{}")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  crmClient     CrmClient      @relation(fields: [crmClientId], references: [id], onDelete: Cascade)
  agents        Agent[]
  conversations Conversation[]

  @@unique([crmClientId, name])
  @@index([crmClientId])
  @@map("departments")
}

model Agent {
  id            String         @id @default(cuid())
  crmClientId   String         @map("crm_client_id")
  departmentId  String?        @map("department_id")
  name          String
  email         String
  passwordHash  String?        @map("password_hash")
  role          UserRole       @default(agent)
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  crmClient     CrmClient      @relation(fields: [crmClientId], references: [id], onDelete: Cascade)
  department    Department?    @relation(fields: [departmentId], references: [id])
  conversations Conversation[]

  @@unique([crmClientId, email])
  @@index([crmClientId])
  @@map("agents")
}

model LeadStatus {
  id          String        @id @default(cuid())
  crmClientId String        @map("crm_client_id")
  name        String
  color       String
  order       Int           @default(0)
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  crmClient   CrmClient     @relation(fields: [crmClientId], references: [id], onDelete: Cascade)
  customers   EndCustomer[]

  @@unique([crmClientId, name])
  @@index([crmClientId])
  @@map("lead_statuses")
}

model LeadSource {
  id          String        @id @default(cuid())
  crmClientId String        @map("crm_client_id")
  name        String
  color       String
  code        String?       // palavra-chave do link rastreável (wa.me)
  order       Int           @default(0)
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  crmClient   CrmClient     @relation(fields: [crmClientId], references: [id], onDelete: Cascade)
  customers   EndCustomer[]

  @@unique([crmClientId, name])
  @@unique([crmClientId, code])
  @@index([crmClientId])
  @@map("lead_sources")
}

model EndCustomer {
  id                  String                 @id @default(cuid())
  crmClientId         String                 @map("crm_client_id")
  leadStatusId        String?                @map("lead_status_id")
  leadSourceId        String?                @map("lead_source_id")
  sourceUrl           String?                @map("source_url")
  sourceRef           String?                @map("source_ref")
  fullName            String                 @map("full_name")
  companyName         String?                @map("company_name")
  phone               String?
  whatsappJid         String?                @map("whatsapp_jid")
  instagramHandle     String?                @map("instagram_handle")
  email               String?
  documentNumber      String?                @map("document_number")
  originChannel       ChannelType            @map("origin_channel")
  lifecycleStage      CustomerLifecycleStage @map("lifecycle_stage")
  leadTemperature     LeadTemperature        @map("lead_temperature")
  priority            Priority
  score               Int                    @default(0)
  estimatedValueCents Int                    @default(0) @map("estimated_value_cents")
  assignedTo          String?                @map("assigned_to")
  lastContactAt       DateTime?              @map("last_contact_at")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")
  crmClient           CrmClient              @relation(fields: [crmClientId], references: [id], onDelete: Cascade)
  leadStatus          LeadStatus?            @relation(fields: [leadStatusId], references: [id])
  leadSource          LeadSource?            @relation(fields: [leadSourceId], references: [id])
  conversations       Conversation[]
  labels              EndCustomerLabel[]
  tasks               Task[]
  scheduledMessages   ScheduledMessage[]

  // Evita clientes duplicados em corrida (dois webhooks do mesmo contato em
  // paralelo). Postgres trata NULLs como distintos, então telefones/jids nulos
  // não conflitam entre si.
  @@unique([crmClientId, phone])
  @@unique([crmClientId, whatsappJid])
  @@index([crmClientId])
  @@index([lifecycleStage])
  @@index([leadStatusId])
  @@index([leadSourceId])
  @@map("end_customers")
}

model Label {
  id          String             @id @default(cuid())
  crmClientId String?            @map("crm_client_id")
  name        String
  color       String
  category    LabelCategory
  crmClient   CrmClient?         @relation(fields: [crmClientId], references: [id], onDelete: Cascade)
  customers   EndCustomerLabel[]

  @@unique([crmClientId, name])
  @@index([crmClientId])
  @@map("labels")
}

model EndCustomerLabel {
  endCustomerId String      @map("end_customer_id")
  labelId       String      @map("label_id")
  endCustomer   EndCustomer @relation(fields: [endCustomerId], references: [id], onDelete: Cascade)
  label         Label       @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([endCustomerId, labelId])
  @@map("end_customer_labels")
}

model Conversation {
  id                 String             @id @default(cuid())
  crmClientId        String             @map("crm_client_id")
  endCustomerId      String             @map("end_customer_id")
  departmentId       String?            @map("department_id")
  assignedAgentId    String?            @map("assigned_agent_id")
  channelType        ChannelType        @map("channel_type")
  status             ConversationStatus
  stage              String
  slaStatus          SlaStatus          @map("sla_status")
  lastMessagePreview String             @map("last_message_preview")
  lastMessageAt      DateTime           @map("last_message_at")
  unreadCount        Int                @default(0) @map("unread_count")
  closedAt           DateTime?          @map("closed_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  crmClient          CrmClient          @relation(fields: [crmClientId], references: [id], onDelete: Cascade)
  endCustomer        EndCustomer        @relation(fields: [endCustomerId], references: [id], onDelete: Cascade)
  department         Department?        @relation(fields: [departmentId], references: [id])
  assignedAgent      Agent?             @relation(fields: [assignedAgentId], references: [id])
  messages           Message[]
  scheduledMessages  ScheduledMessage[]

  @@index([channelType, status])
  @@index([endCustomerId])
  @@index([departmentId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  senderType     SenderType   @map("sender_type")
  senderName     String       @map("sender_name")
  body           String
  mediaType      String?      @map("media_type")
  mediaUrl       String?      @map("media_url")
  sentAt         DateTime     @map("sent_at")
  readAt         DateTime?    @map("read_at")
  waMessageId    String?      @unique @map("wa_message_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
  @@map("messages")
}

model QuickMessage {
  id           String    @id @default(cuid())
  crmClientId  String    @map("crm_client_id")
  departmentId String?   @map("department_id")
  shortcut     String
  title        String
  body         String
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  crmClient    CrmClient @relation(fields: [crmClientId], references: [id], onDelete: Cascade)

  @@unique([crmClientId, shortcut])
  @@index([crmClientId])
  @@map("quick_messages")
}

model ScheduledMessage {
  id             String                 @id @default(cuid())
  crmClientId    String                 @map("crm_client_id")
  conversationId String?                @map("conversation_id")
  endCustomerId  String?                @map("end_customer_id")
  agentId        String?                @map("agent_id")
  body           String
  scheduledAt    DateTime               @map("scheduled_at")
  sentAt         DateTime?              @map("sent_at")
  status         ScheduledMessageStatus @default(pending)
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  crmClient      CrmClient              @relation(fields: [crmClientId], references: [id], onDelete: Cascade)
  conversation   Conversation?          @relation(fields: [conversationId], references: [id])
  endCustomer    EndCustomer?           @relation(fields: [endCustomerId], references: [id])

  @@index([scheduledAt, status])
  @@index([crmClientId])
  @@map("scheduled_messages")
}

model Setting {
  id          String    @id @default(cuid())
  crmClientId String    @map("crm_client_id")
  key         String
  value       String
  updatedAt   DateTime  @updatedAt @map("updated_at")
  crmClient   CrmClient @relation(fields: [crmClientId], references: [id], onDelete: Cascade)

  @@unique([crmClientId, key])
  @@index([crmClientId])
  @@map("settings")
}

model Task {
  id            String       @id @default(cuid())
  crmClientId   String       @map("crm_client_id")
  endCustomerId String?      @map("end_customer_id")
  title         String
  status        TaskStatus
  dueAt         DateTime?    @map("due_at")
  ownerName     String       @map("owner_name")
  createdAt     DateTime     @default(now()) @map("created_at")
  crmClient     CrmClient    @relation(fields: [crmClientId], references: [id], onDelete: Cascade)
  endCustomer   EndCustomer? @relation(fields: [endCustomerId], references: [id], onDelete: Cascade)

  @@index([crmClientId])
  @@index([endCustomerId])
  @@map("tasks")
}
